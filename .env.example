# ==============================================================================
# Knovana Docker Compose Production Environment Configuration (Example)
# ==============================================================================
# Copy this file to '.env' at the project root folder before running 'docker compose up -d'

# 1. System & Server Settings
# In docker container, host should be 0.0.0.0 to allow mapping to host machine
NODE_ENV=production
KNOVANA_HOST=0.0.0.0
KNOVANA_PORT=8000

# 2. Security & Auth Settings
# JWT Secret Key: MUST be changed in production to a secure random string!
# You can generate a secure secret key using: openssl rand -base64 32
KNOVANA_JWT_SECRET=l9VISQ2o69dXDnURpvZ+i3CImgxn8LOvPQqalYrUeGE=
KNOVANA_JWT_EXPIRE_DAYS=30

# Administrator account credentials (synced to SQLite automatically on startup/login)
KNOVANA_ADMIN_USERNAME=admin
KNOVANA_ADMIN_PASSWORD=password@

# CORS Origins: comma-separated list of allowed origins.
# Allows Chrome Extensions side panel and local frontend web dev environments.
KNOVANA_CORS_ORIGINS=chrome-extension://*,http://localhost:*,http://127.0.0.1:*

# 3. LLM & Agent Settings (DeepSeek / Anthropic API Compatibility)
# DeepSeek API endpoint mapping (compatible with Anthropic SDK structure)
# E.g. https://api.deepseek.com/anthropic or https://api.deepseek.com/v1
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# DeepSeek Authentication Token / API Key
ANTHROPIC_AUTH_TOKEN=your-deepseek-api-key-here

# Main Claude SDK model routing to DeepSeek models
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash

# Claude Code subagents configuration
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max
